      "close_on_or_after": "2026-05-01",
      "close_on_or_before": "2026-07-31"
    },
    "source_contract": {
      "canonical_config": "core/config/source-contracts.json",
      "source_of_truth": {
        "salesforce": "salesforce",
        "gmail": "gmail",
        "google_calendar": "google_calendar",
        "zoom": "zoom",
        "slack": "slack",
        "google_drive": "google_drive"
      },
      "clean_negative_requires_successful_connector_read": true,
      "missing_connector_read": "coverage_gap",
      "cross_source_substitution_allowed": false
    },
    "large_run_threshold": 15,
    "per_deal_connectors": [
      "Salesforce",
      "Gmail",
      "Google Calendar",
      "Zoom",
      "Slack",
      "Google Drive"
    ],
    "internal_evidence": {
      "mode": "force",
      "window_days": 30,
      "mapping_fields": [],
      "source_contract": {
        "canonical_config": "core/config/source-contracts.json",
        "source_of_truth": {
          "slack": "slack",
          "google_drive": "google_drive"
        },
        "clean_negative_requires_successful_connector_read": true,
        "missing_connector_read": "coverage_gap",
        "cross_source_substitution_allowed": false
      },
      "max_messages": 40,
      "max_linked_docs": 3,
      "signals": [
        "deal_desk_blocker",
        "legal_blocker",
        "procurement_blocker",
        "security_blocker",
        "product_gap",
        "exec_alignment",
        "implementation_risk",
        "pricing_approval",
        "competitive_context",
        "clm_stage",
        "legal_task_stage"
      ],
      "broad_search_allowed": true,
      "slack": {
        "source": "slack",
        "connector": "slack_mcp",
        "source_contract": {
          "source_of_truth": "slack",
          "owns": [
            "slack channels",
            "slack messages",
            "slack deal-room existence",
            "slack internal activity"
          ],
          "does_not_own": [
            "salesforce opportunity fields",
            "gmail activity",
            "calendar activity",
            "zoom/call content"
          ],
          "required_search": [
            "search Slack MCP directly by account/company/channel-name variants"
          ]
        },
        "salesforce_mapping_allowed": false,
        "query_type": "bounded_fallback_lookup",
        "steps": [
          {
            "step": 1,
            "action": "slack_search_channels",
            "terms": [],
            "channel_types": "public_channel,private_channel",
            "on_match": "read up to max_messages from the matched channel; set coverage=found; skip step 2",
            "on_no_match": "proceed to step 2"
          },
          {
            "step": 2,
            "action": "slack_search_public_and_private",
            "terms": [],
            "window_days": 30,
            "on_match": "capture signals with source_refs; set coverage=checked_no_match",
            "on_no_match": "set coverage=checked_no_match; no signals"
          }
        ],
        "terms": [],
        "window_days": 30,
        "max_messages": 40,
        "broad_search_allowed": true,
        "requires_internal_force": true,
        "coverage_requirements": {
          "checked_bundle_field": "internal_evidence.slack_mcp_checked",
          "searched_channels_bundle_field": "internal_evidence.slack_channels_searched",
          "channel_matches_bundle_field": "internal_evidence.slack_channel_matches",
          "deal_room_coverage_bundle_field": "internal_evidence.deal_room.coverage",
          "deal_room_source_ref_bundle_field": "internal_evidence.deal_room.source_ref",
          "clean_negative_rule": "Only claim no Slack room/activity after Slack MCP channel search completed and searched channels are recorded."
        }
      },
      "linked_docs": {
        "source": "google_drive",
        "source_contract": {
          "source_of_truth": "google_drive",
          "owns": [
            "google drive docs",
            "proposal document content",
            "linked document metadata"
          ],
          "does_not_own": [
            "salesforce opportunity fields",
            "gmail threads",
            "slack activity",
            "calendar events",
            "zoom/call content"
          ],
          "required_search": []
