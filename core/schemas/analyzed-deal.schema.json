{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyzedDeal",
  "type": "object",
  "required": ["deal_metrics", "account_history"],
  "properties": {
    "deal_metrics": { "type": "object" },
    "call_execution": { "type": ["object", "null"] },
    "account_history": { "type": "object" },
    "calendar_evidence": { "type": ["object", "null"] },
    "internal_evidence": { "type": ["object", "null"] },
    "confidence": {
      "type": "object",
      "properties": {
        "max_label": { "enum": ["Low", "Medium", "High"] },
        "reason_codes": { "type": "array", "items": { "type": "string" } },
        "coverage_gaps": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "source_gaps": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
