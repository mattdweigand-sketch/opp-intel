{
  "_comment": "Chosen Salesforce field/query mapping for plan.py. Edit this to retarget another org — it's the one place SOQL field names live, so the model never improvises them (that caused the 'Amount' error). Discover real names with getObjectSchema once, then record them here.",
  "opportunity_fields": [
    "Id", "Name", "StageName", "ForecastCategory", "Probability", "Type",
    "Added_ARR__c", "Calculated_ACV__c", "Amount__c", "Full_Deal_Amount__c",
    "Added_ACV_Fund_Admin__c", "Added_GPX_Forecast__c",
    "CloseDate", "CreatedDate", "LastActivityDate",
    "NextStep", "Next_Steps_Last_Modified_Date__c", "SE_Next_Steps__c", "SE_Next_Step_Date__c",
    "Gong_Competitors_Mentioned__c", "JSQ_Competitive_With__c", "Competition_Justification__c",
    "Champion_WdB__c", "Decision_Maker__c",
    "Pain_Need__c", "Decision_Process_Justification__c", "Decision_Criteria_Justification__c",
    "Legal_Status__c", "Fund_Admin_Proposal_Approval_Status__c",
    "Critical_Event__c", "Last_Meaningful_Event__c", "Last_Meaningful_Event_Date__c"
  ],
  "find_fields": ["Id", "Name", "StageName", "CloseDate", "LastActivityDate", "OwnerId", "AccountId"],
  "amount_basis": {
    "default": "acv",
    "fields": {
      "acv": "Added_ARR__c",
      "crm_primary_amount": "Amount__c"
    }
  },
  "forecast_category": {
    "field": "ForecastCategoryName",
    "convention": {
      "commit": ["Commit"],
      "upside": ["Best Case", "Upside"],
      "pipeline": ["Pipeline"]
    }
  },
  "pipeline_scope": {
    "_comment": "The portfolio list query: every open opp the running rep owns whose CloseDate falls inside the window. OwnerId is resolved at runtime via getUserInfo. Fiscal quarter bounds come from plan.py using the Feb 1 fiscal-year start in risk-model.json.",
    "fields": ["Id", "Name", "StageName", "CloseDate", "Added_ARR__c", "Calculated_ACV__c", "Amount__c", "AccountId", "OwnerId", "LastActivityDate", "ForecastCategoryName", "NextStep"],
    "account_name_field": "Account.Name",
    "owner_filter": "OwnerId = '{owner_id}'",
    "open_filter": "IsClosed = false",
    "order_by": "CloseDate ASC"
  },
  "hygiene_scope": {
    "_comment": "SF-only hygiene scan. No Gmail, Calendar, Zoom, Slack, or Drive.",
    "contact_roles_sobject": "OpportunityContactRole",
    "contact_roles_fields": ["OpportunityId", "Role", "IsPrimary", "Contact.Name", "Contact.Email"],
    "opportunity_id_field": "OpportunityId"
  },
  "prior_opp_fields": [
    "Id", "Name", "StageName", "CloseDate", "IsWon",
    "JSQ_Loss_Reason__c", "Lost_Reason__c", "Primary_Risk_Lost_Reason__c",
    "JSQ_Loss_Notes__c", "JSQ_Sales_Stage_When_Lost__c", "Competitor_Lost_to_Fund_admin__c"
  ],
  "internal_sources": {
    "slack_deal_room": {
      "mapping_fields": [],
      "fallback_lookup": "account_or_opportunity_name",
      "channel_lookup_in_auto": true,
      "message_search_requires_internal_force": true
    },
    "linked_docs": {
      "allowed_sources": ["google_drive"],
      "relationship": "linked_from_deal_room"
    }
  },
  "contact_fields": ["Id", "Name", "Title", "Email", "Role", "IsPrimary"],
  "task_fields": ["Id", "Subject", "ActivityDate", "Status", "TaskSubtype"],
  "history_fields": ["Id", "StageName", "CloseDate", "CreatedDate"],
  "contact_roles_relationship": "OpportunityContactRoles"
}
